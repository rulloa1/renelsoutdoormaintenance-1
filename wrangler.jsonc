{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "renelsoutdoormaintenance-1",
  "compatibility_date": "2026-04-03",
  "main": "./worker.ts",
  "build": {
    "command": "npm install --legacy-peer-deps && npx vite build"
  },
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "./public"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
